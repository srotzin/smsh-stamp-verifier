{
  "name": "@hivecivilization/smsh-stamp-verifier",
  "version": "0.1.0",
  "description": "Regulator-friendly cryptographic verification for SMSH-Stamp v1 AI/agent compliance receipts. Zero runtime dependency, pure Ed25519 + SHA-256 + JCS.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "smsh-verify": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "provenance",
    "ed25519",
    "attestation",
    "compliance",
    "smsh",
    "hive"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/srotzin/smsh-stamp-verifier.git"
  },
  "homepage": "https://github.com/srotzin/smsh-stamp-verifier#readme",
  "bugs": {
    "url": "https://github.com/srotzin/smsh-stamp-verifier/issues"
  },
  "author": "Hive Civilization",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.1.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
